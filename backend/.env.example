# --- required ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- optional (defaults shown) ---
PORT=4000
GEMINI_MODEL=gemini-2.5-flash
# Comma-separated list of allowed origins, or * for any
CORS_ORIGIN=*
# Rows per AI request
BATCH_SIZE=100
# AI batches processed in parallel
BATCH_CONCURRENCY=3
# Attempts per batch before its rows are reported as skipped
AI_MAX_RETRIES=3
MAX_ROWS=2000
MAX_FILE_SIZE_MB=10
# Per-IP cap on AI imports (CRM-format passthrough imports are exempt); 0 disables
IMPORT_RATE_LIMIT=5
IMPORT_RATE_WINDOW_MIN=10
